rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow authenticated users to upload review images
    match /reviews/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.resource.size < 5 * 1024 * 1024; // 5MB limit
    }

    // Allow authenticated users to upload service images
    match /services/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.resource.size < 10 * 1024 * 1024; // 10MB limit
    }

    // Allow authenticated users to upload profile images
    match /profiles/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == request.resource.name.split('_')[0] && request.resource.size < 5 * 1024 * 1024; // 5MB limit
    }
  }
}